{
  "name": "youda-reborn",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" run dev",
    "build": "pnpm --filter web build",
    "build:all": "pnpm --filter \"./apps/*\" run build",
    "test": "pnpm --filter \"./apps/*\" run test",
    "lint": "pnpm --filter \"./apps/*\" run lint"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@youda/game-assets": "workspace:*"
  }
}
