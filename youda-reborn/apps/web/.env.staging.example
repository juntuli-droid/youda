APP_ENV=staging
APP_BASE_URL=https://staging.youda.example.com
DATABASE_URL=mysql://user:password@staging-db:3306/youda_staging
DIRECT_DATABASE_URL=mysql://user:password@staging-db:3306/youda_staging
JWT_SECRET=replace-with-staging-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-staging-refresh-secret-min-32
REDIS_URL=redis://staging-redis:6379
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@staging.youda.example.com
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=d-staging-reset
SENDGRID_SUSPICIOUS_LOGIN_TEMPLATE_ID=d-staging-suspicious
SENDGRID_LOGIN_CHALLENGE_TEMPLATE_ID=d-staging-challenge
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=youda
SENTRY_PROJECT=web
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
ALERT_EMAIL_TO=ops-staging@example.com
RTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn-staging.youda.example.com:3478?transport=udp"],"username":"turn-user","credential":"turn-password"}]
TURN_SHARED_SECRET=replace-with-staging-turn-rest-secret
TURN_UDP_URL=turn:turn-staging.youda.example.com:3478?transport=udp
TURN_TLS_URL=turns:turn-staging.youda.example.com:5349?transport=tcp
TURN_CREDENTIAL_TTL_SECONDS=3600
