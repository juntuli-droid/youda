APP_ENV=production
APP_BASE_URL=https://youda.example.com
DATABASE_URL=mysql://user:password@production-db:3306/youda_prod
DIRECT_DATABASE_URL=mysql://user:password@production-db:3306/youda_prod
JWT_SECRET=replace-with-production-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-production-refresh-secret-min-32
REDIS_URL=redis://production-redis:6379
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@youda.example.com
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=d-production-reset
SENDGRID_SUSPICIOUS_LOGIN_TEMPLATE_ID=d-production-suspicious
SENDGRID_LOGIN_CHALLENGE_TEMPLATE_ID=d-production-challenge
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=youda
SENTRY_PROJECT=web
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
ALERT_EMAIL_TO=ops@youda.example.com
RTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.youda.example.com:3478?transport=udp"],"username":"turn-user","credential":"turn-password"}]
TURN_SHARED_SECRET=replace-with-production-turn-rest-secret
TURN_UDP_URL=turn:turn.youda.example.com:3478?transport=udp
TURN_TLS_URL=turns:turn.youda.example.com:5349?transport=tcp
TURN_CREDENTIAL_TTL_SECONDS=3600
