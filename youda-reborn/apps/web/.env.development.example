APP_ENV=development
APP_BASE_URL=http://localhost:3000
DATABASE_URL=mysql://user:password@127.0.0.1:3306/youda_dev
DIRECT_DATABASE_URL=mysql://user:password@127.0.0.1:3306/youda_dev
JWT_SECRET=replace-with-development-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-development-refresh-secret-min-32
REDIS_URL=redis://127.0.0.1:6379
SENDGRID_API_KEY=replace-with-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_PASSWORD_RESET_TEMPLATE_ID=d-development-reset
SENDGRID_SUSPICIOUS_LOGIN_TEMPLATE_ID=d-development-suspicious
SENDGRID_LOGIN_CHALLENGE_TEMPLATE_ID=d-development-challenge
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=youda
SENTRY_PROJECT=web
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
ALERT_EMAIL_TO=ops@example.com
RTC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478?transport=udp"],"username":"turn-user","credential":"turn-password"}]
TURN_SHARED_SECRET=replace-with-turn-rest-secret
TURN_UDP_URL=turn:turn.example.com:3478?transport=udp
TURN_TLS_URL=turns:turn.example.com:5349?transport=tcp
TURN_CREDENTIAL_TTL_SECONDS=3600
